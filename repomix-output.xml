                boxShadow: isSelected ? [BoxShadow(color: const Color(0xFF3B82F6).withAlpha(80), blurRadius: 10)] : [],
              ),
              child: Center(
                child: Text(
                  filter,
                  style: TextStyle(
                    color: isSelected ? Colors.white : const Color(0xFF4B5563),
