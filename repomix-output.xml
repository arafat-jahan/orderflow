              });
              Navigator.pop(context);
            },
            child: const Text('Update', style: TextStyle(color: Color(0xFF3B82F6))),
          ),
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    if (!_isKeySaved) return _buildSetupView();

    return Scaffold(
